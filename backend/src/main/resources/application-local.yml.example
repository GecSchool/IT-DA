spring:
  datasource:
    url: jdbc:mysql://localhost:3306/itda?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
    username: root
    password: 여기에-MySQL-비밀번호
    driver-class-name: com.mysql.cj.jdbc.Driver
  jpa:
    hibernate:
      ddl-auto: update
    show-sql: true
    properties:
      hibernate:
        format_sql: true
  security:
    oauth2:
      client:
        registration:
          google:
            client-id: 여기에-구글-클라이언트-ID
            client-secret: 여기에-구글-클라이언트-시크릿
            scope: profile, email

jwt:
  secret: 여기에-32자-이상-아무-문자열-itda-jwt-secret
  access-token-expiration: 1800000
  refresh-token-expiration: 1296000000

frontend:
  url: http://localhost:3000
